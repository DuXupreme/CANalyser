<UserControl x:Class="CanAnalyzer.App.Views.DbcEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:infra="clr-namespace:CanAnalyzer.App.Infrastructure"
             mc:Ignorable="d">
    <UserControl.Resources>
        <infra:FlexibleDoubleConverter x:Key="FlexDouble" />
    </UserControl.Resources>

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0"
                BorderBrush="#DDDDDD"
                BorderThickness="1"
                CornerRadius="4"
                Padding="6"
                Margin="0,0,0,6">
            <WrapPanel>
                <Button Content="Nieuwe database" Command="{Binding NewDatabaseCommand}" Margin="0,0,6,0" />
                <Button Content="Open DBC..." Command="{Binding OpenDbcCommand}" Margin="0,0,6,0" />
                <Button Content="Opslaan als DBC..." Command="{Binding SaveDbcCommand}" Margin="0,0,12,0" />
                <Separator Margin="0,0,12,0" />
                <Button Content="+ Frame" Command="{Binding AddFrameCommand}" Margin="0,0,6,0" />
                <Button Content="- Frame" Command="{Binding RemoveFrameCommand}" />
            </WrapPanel>
        </Border>

        <TextBlock Grid.Row="1"
                   Text="{Binding StatusText}"
                   Foreground="#444444"
                   TextTrimming="CharacterEllipsis"
                   Margin="2,0,0,6" />

        <!-- Master / detail -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="340" />
                <ColumnDefinition Width="6" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Frame list -->
            <GroupBox Grid.Column="0" Header="Frames (berichten)">
                <DataGrid ItemsSource="{Binding Frames}"
                          SelectedItem="{Binding SelectedFrame, Mode=TwoWay}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding FrameIdText}" Width="90" />
                        <DataGridCheckBoxColumn Header="Ext" Binding="{Binding IsExtended}" Width="40" />
                        <DataGridTextColumn Header="Naam" Binding="{Binding Name}" Width="*" />
                        <DataGridTextColumn Header="DLC" Binding="{Binding Dlc}" Width="45" />
                        <DataGridTextColumn Header="#Sig" Binding="{Binding SignalCount}" Width="45" IsReadOnly="True" />
                    </DataGrid.Columns>
                </DataGrid>
            </GroupBox>

            <GridSplitter Grid.Column="1" Width="6" HorizontalAlignment="Stretch" Background="#EEEEEE" />

            <!-- Detail -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Frame properties -->
                <GroupBox Grid.Row="0" Header="Frame-eigenschappen" Margin="0,0,0,6">
                    <WrapPanel Margin="6">
                        <StackPanel Margin="0,0,12,4">
                            <TextBlock Text="Naam" />
                            <TextBox Width="180"
                                     Text="{Binding SelectedFrame.Name, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                        <StackPanel Margin="0,0,12,4">
                            <TextBlock Text="CAN ID (hex of dec)" />
                            <TextBox Width="120" Text="{Binding SelectedFrame.FrameIdText}" />
                        </StackPanel>
                        <StackPanel Margin="0,0,12,4">
                            <TextBlock Text="Extended" />
                            <CheckBox IsChecked="{Binding SelectedFrame.IsExtended}"
                                      Content="29-bit"
                                      VerticalAlignment="Center"
                                      Margin="0,4,0,0" />
                        </StackPanel>
                        <StackPanel Margin="0,0,12,4">
                            <TextBlock Text="DLC (bytes)" />
                            <TextBox Width="60" Text="{Binding SelectedFrame.Dlc}" />
                        </StackPanel>
                    </WrapPanel>
                </GroupBox>

                <!-- Signals toolbar -->
                <DockPanel Grid.Row="1" Margin="0,0,0,4" LastChildFill="False">
                    <TextBlock DockPanel.Dock="Left"
                               Text="Signalen in geselecteerd frame"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                    <Button DockPanel.Dock="Right"
                            Content="- Signaal"
                            Command="{Binding RemoveSignalCommand}" />
                    <Button DockPanel.Dock="Right"
                            Content="+ Signaal"
                            Command="{Binding AddSignalCommand}"
                            Margin="0,0,6,0" />
                </DockPanel>

                <!-- Signals grid -->
                <DataGrid Grid.Row="2"
                          ItemsSource="{Binding SelectedFrame.Signals}"
                          SelectedItem="{Binding SelectedSignal, Mode=TwoWay}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          HeadersVisibility="Column"
                          GridLinesVisibility="All">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Naam" Binding="{Binding Name}" Width="150" />
                        <DataGridTextColumn Header="Start" Binding="{Binding StartBit}" Width="50" />
                        <DataGridTextColumn Header="Len" Binding="{Binding Length}" Width="45" />
                        <DataGridCheckBoxColumn Header="Intel" Binding="{Binding LittleEndian}" Width="45" />
                        <DataGridCheckBoxColumn Header="±" Binding="{Binding Signed}" Width="35" />
                        <DataGridTextColumn Header="Scale" Binding="{Binding Scale, Converter={StaticResource FlexDouble}}" Width="65" />
                        <DataGridTextColumn Header="Offset" Binding="{Binding Offset, Converter={StaticResource FlexDouble}}" Width="65" />
                        <DataGridTextColumn Header="Min" Binding="{Binding Minimum, Converter={StaticResource FlexDouble}}" Width="65" />
                        <DataGridTextColumn Header="Max" Binding="{Binding Maximum, Converter={StaticResource FlexDouble}}" Width="65" />
                        <DataGridTextColumn Header="Unit" Binding="{Binding Unit}" Width="60" />
                        <DataGridTextColumn Header="Mux" Binding="{Binding MuxText}" Width="50" />
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Validation -->
                <Border Grid.Row="3"
                        Background="#F7F7F7"
                        BorderBrush="#E0E0E0"
                        BorderThickness="1"
                        CornerRadius="3"
                        Padding="6,3"
                        Margin="0,6,0,6">
                    <TextBlock Text="{Binding ValidationSummary}" FontWeight="SemiBold" TextWrapping="Wrap" />
                </Border>

                <!-- Bit layout -->
                <GroupBox Grid.Row="4" Header="Bit-layout (LSB0 — byte 0 boven, MSB links)">
                    <StackPanel Orientation="Horizontal" Margin="6">
                        <!-- Byte labels -->
                        <StackPanel>
                            <Border Height="16" />
                            <TextBlock Text="B0" Height="26" Width="24" TextAlignment="Right" VerticalAlignment="Center" FontSize="10" Foreground="#666" />
                            <TextBlock Text="B1" Height="26" Width="24" TextAlignment="Right" VerticalAlignment="Center" FontSize="10" Foreground="#666" />
                            <TextBlock Text="B2" Height="26" Width="24" TextAlignment="Right" VerticalAlignment="Center" FontSize="10" Foreground="#666" />
                            <TextBlock Text="B3" Height="26" Width="24" TextAlignment="Right" VerticalAlignment="Center" FontSize="10" Foreground="#666" />
                            <TextBlock Text="B4" Height="26" Width="24" TextAlignment="Right" VerticalAlignment="Center" FontSize="10" Foreground="#666" />
                            <TextBlock Text="B5" Height="26" Width="24" TextAlignment="Right" VerticalAlignment="Center" FontSize="10" Foreground="#666" />
                            <TextBlock Text="B6" Height="26" Width="24" TextAlignment="Right" VerticalAlignment="Center" FontSize="10" Foreground="#666" />
                            <TextBlock Text="B7" Height="26" Width="24" TextAlignment="Right" VerticalAlignment="Center" FontSize="10" Foreground="#666" />
                        </StackPanel>
                        <StackPanel Margin="4,0,0,0">
                            <!-- Bit-position header (MSB left) -->
                            <StackPanel Orientation="Horizontal" Height="16">
                                <TextBlock Text="7" Width="32" TextAlignment="Center" FontSize="10" Foreground="#666" />
                                <TextBlock Text="6" Width="32" TextAlignment="Center" FontSize="10" Foreground="#666" />
                                <TextBlock Text="5" Width="32" TextAlignment="Center" FontSize="10" Foreground="#666" />
                                <TextBlock Text="4" Width="32" TextAlignment="Center" FontSize="10" Foreground="#666" />
                                <TextBlock Text="3" Width="32" TextAlignment="Center" FontSize="10" Foreground="#666" />
                                <TextBlock Text="2" Width="32" TextAlignment="Center" FontSize="10" Foreground="#666" />
                                <TextBlock Text="1" Width="32" TextAlignment="Center" FontSize="10" Foreground="#666" />
                                <TextBlock Text="0" Width="32" TextAlignment="Center" FontSize="10" Foreground="#666" />
                            </StackPanel>
                            <ItemsControl ItemsSource="{Binding BitCells}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Rows="8" Columns="8" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Width="30"
                                                Height="24"
                                                Margin="1"
                                                CornerRadius="2"
                                                Background="{Binding FillBrush}"
                                                BorderBrush="#BBBBBB"
                                                BorderThickness="1"
                                                ToolTip="{Binding Tooltip}">
                                            <TextBlock Text="{Binding BitLabel}"
                                                       FontSize="9"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Foreground="#333333" />
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock Text="Tip: kleur = signaal, rood = overlap. Beweeg de muis over een cel voor byte.bit en signaalnaam."
                                       FontSize="10"
                                       Foreground="#888"
                                       Margin="0,4,0,0" />
                        </StackPanel>
                    </StackPanel>
                </GroupBox>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
