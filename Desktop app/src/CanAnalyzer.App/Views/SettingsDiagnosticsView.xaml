<UserControl x:Class="CanAnalyzer.App.Views.SettingsDiagnosticsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="350" />
            <ColumnDefinition Width="12" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0">
            <GroupBox Header="Actieve bestanden" Margin="0,0,0,8">
                <StackPanel Margin="8">
                    <TextBlock Text="Logbestand" FontWeight="SemiBold" />
                    <TextBox Text="{Binding LogFilePath}" IsReadOnly="True" TextWrapping="Wrap" Margin="0,2,0,8" />
                    <TextBlock Text="DBC-bestand" FontWeight="SemiBold" />
                    <TextBox Text="{Binding DbcFilePath}" IsReadOnly="True" TextWrapping="Wrap" Margin="0,2,0,0" />
                </StackPanel>
            </GroupBox>

            <GroupBox Header="Recente logbestanden" Margin="0,0,0,8">
                <ListBox ItemsSource="{Binding RecentLogFiles}" Height="120" />
            </GroupBox>

            <GroupBox Header="Recente DBC-bestanden" Margin="0,0,0,8">
                <ListBox ItemsSource="{Binding RecentDbcFiles}" Height="120" />
            </GroupBox>

            <GroupBox Header="Settings opslag">
                <StackPanel Margin="8">
                    <TextBlock Text="Instellingenbestand" FontWeight="SemiBold" />
                    <TextBox Text="{Binding SettingsFilePath}" IsReadOnly="True" TextWrapping="Wrap" />
                </StackPanel>
            </GroupBox>

            <GroupBox Header="Updates" Margin="0,8,0,0">
                <StackPanel Margin="8">
                    <TextBlock>
                        <Run Text="Huidige versie: " FontWeight="SemiBold" />
                        <Run Text="{Binding AppVersion, Mode=OneWay}" />
                    </TextBlock>
                    <Button Content="Controleer op updates"
                            Command="{Binding CheckForUpdatesCommand}"
                            Margin="0,8,0,0" />
                    <TextBlock Text="{Binding UpdateStatus}" TextWrapping="Wrap" Margin="0,6,0,0" />
                </StackPanel>
            </GroupBox>

            <GroupBox Header="Programma-instellingen" Margin="0,8,0,0">
                <StackPanel Margin="8">
                    <TextBlock Text="Max punten per trace (default)" />
                    <TextBox Text="{Binding DefaultMaxPointsPerTrace, UpdateSourceTrigger=PropertyChanged}" Margin="0,2,0,6" />

                    <TextBlock Text="Subplot hoogte [px] (default)" />
                    <TextBox Text="{Binding DefaultSubplotHeight, UpdateSourceTrigger=PropertyChanged}" Margin="0,2,0,6" />

                    <TextBlock Text="Signaallijst hoogte [px] (default)" />
                    <TextBox Text="{Binding DefaultSignalListHeight, UpdateSourceTrigger=PropertyChanged}" Margin="0,2,0,6" />

                    <TextBlock Text="Max rijen Raw Frames (default)" />
                    <TextBox Text="{Binding DefaultRawMaxRows, UpdateSourceTrigger=PropertyChanged}" Margin="0,2,0,6" />

                    <CheckBox Content="Snelheidsmodus / downsampling standaard aan"
                              IsChecked="{Binding DefaultUseDownsampling}"
                              Margin="0,0,0,6" />

                    <CheckBox Content="Toon legenda standaard"
                              IsChecked="{Binding DefaultShowLegend}"
                              Margin="0,0,0,8" />

                    <CheckBox Content="Koppel X-assen standaard"
                              IsChecked="{Binding DefaultLinkXAxisAcrossPanels}"
                              Margin="0,0,0,8" />

                    <Button Content="Instellingen toepassen en opslaan"
                            Command="{Binding ApplyProgramSettingsCommand}" />
                    <TextBlock Text="{Binding SettingsSaveStatus}" Margin="0,6,0,0" />
                </StackPanel>
            </GroupBox>
        </StackPanel>

        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <GroupBox Grid.Row="0" Header="Laatste bewerking" Margin="0,0,0,8">
                <TextBox Margin="8"
                         IsReadOnly="True"
                         FontFamily="Consolas"
                         Text="{Binding LastOperationSummary}"
                         TextWrapping="Wrap" />
            </GroupBox>

            <GroupBox Grid.Row="1" Header="Integriteit / validatie" Margin="0,0,0,8">
                <TextBox Margin="8"
                         IsReadOnly="True"
                         FontFamily="Consolas"
                         Text="{Binding IntegritySummary}"
                         TextWrapping="Wrap" />
            </GroupBox>

            <GroupBox Grid.Row="2" Header="Gedecodeerde berichten" Margin="0,0,0,8">
                <DataGrid ItemsSource="{Binding MessageSummaries}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          Margin="8"
                          EnableRowVirtualization="True"
                          EnableColumnVirtualization="True"
                          VirtualizingPanel.IsVirtualizing="True"
                          VirtualizingPanel.ScrollUnit="Pixel">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Frame ID" Binding="{Binding FrameIdHex}" Width="105" />
                        <DataGridTextColumn Header="Frame ID (dec)" Binding="{Binding FrameId}" Width="110" />
                        <DataGridTextColumn Header="Message" Binding="{Binding MessageName}" Width="*" />
                        <DataGridTextColumn Header="Count" Binding="{Binding Count}" Width="80" />
                    </DataGrid.Columns>
                </DataGrid>
            </GroupBox>

            <GroupBox Grid.Row="3" Header="Debug / decode-details" Margin="0,0,0,8">
                <TextBox Margin="8"
                         IsReadOnly="True"
                         FontFamily="Consolas"
                         VerticalScrollBarVisibility="Auto"
                         Text="{Binding DecodeDiagnostics}"
                         TextWrapping="Wrap" />
            </GroupBox>

            <GroupBox Grid.Row="4" Header="Laatste foutdetails">
                <TextBox Margin="8"
                         IsReadOnly="True"
                         FontFamily="Consolas"
                         VerticalScrollBarVisibility="Auto"
                         Text="{Binding LastErrorDetails}"
                         TextWrapping="Wrap" />
            </GroupBox>
        </Grid>
    </Grid>
</UserControl>
