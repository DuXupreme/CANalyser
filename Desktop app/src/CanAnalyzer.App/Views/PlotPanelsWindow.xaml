<Window x:Class="CanAnalyzer.App.Views.PlotPanelsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:oxy="http://oxyplot.org/wpf"
        mc:Ignorable="d"
        Title="Analyse plots"
        Width="1450"
        Height="950"
        MinWidth="980"
        MinHeight="620">
    <DockPanel Margin="8">
        <Border DockPanel.Dock="Top"
                BorderThickness="1"
                BorderBrush="#DDDDDD"
                CornerRadius="4"
                Padding="6"
                Margin="0,0,0,6">
            <StackPanel>
                <TextBlock Text="Aparte plotweergave: box-selectie zoom (linkermuisknop), pannen (rechtermuisknop), muiswiel zoom."
                           Foreground="#333333" />
                <WrapPanel Margin="0,6,0,0">
                    <StackPanel Margin="0,0,10,0">
                        <TextBlock Text="Subplot hoogte [px]" />
                        <Slider Width="170"
                                Minimum="160"
                                Maximum="1200"
                                TickFrequency="20"
                                IsSnapToTickEnabled="True"
                                Value="{Binding SubplotHeight, Mode=TwoWay}" />
                    </StackPanel>
                    <StackPanel Margin="0,0,10,0">
                        <TextBlock Text="Max punten/trace" />
                        <Slider Width="170"
                                Minimum="200"
                                Maximum="20000"
                                TickFrequency="200"
                                IsSnapToTickEnabled="True"
                                Value="{Binding MaxPointsPerTrace, Mode=TwoWay}" />
                    </StackPanel>
                    <StackPanel Margin="0,0,10,0">
                        <TextBlock Text="Weergave" />
                        <WrapPanel>
                            <CheckBox Content="Trapjes"
                                      IsChecked="{Binding StepPlot, Mode=TwoWay}"
                                      Margin="0,0,8,0" />
                            <CheckBox Content="Markers"
                                      IsChecked="{Binding MarkersOnly, Mode=TwoWay}"
                                      Margin="0,0,8,0" />
                            <CheckBox Content="Legenda"
                                      IsChecked="{Binding ShowLegend, Mode=TwoWay}"
                                      Margin="0,0,8,0" />
                            <CheckBox Content="Snelheidsmodus (downsampling)"
                                      IsChecked="{Binding UseDownsampling, Mode=TwoWay}"
                                      Margin="0,0,8,0" />
                            <CheckBox Content="Koppel Y-assen"
                                      IsChecked="{Binding LinkYAxisAcrossPanels, Mode=TwoWay}"
                                      Margin="0,0,8,0" />
                            <CheckBox Content="Cursorwaardes op lijn"
                                      IsChecked="{Binding ShowCursorValueLabels, Mode=TwoWay}" />
                        </WrapPanel>
                    </StackPanel>
                </WrapPanel>
                <WrapPanel Margin="0,6,0,0">
                    <Button Content="Flag A = cursor" Click="OnSetFlagAFromCursorClick" Margin="0,0,6,0" />
                    <Button Content="Flag B = cursor" Click="OnSetFlagBFromCursorClick" Margin="0,0,6,0" />
                    <Button Content="Volgende verandering (A→B)" Click="OnJumpFlagBToNextChangeClick" Margin="0,0,6,0" />
                    <Button Content="Wis flags" Click="OnClearFlagsClick" Margin="0,0,6,0" />
                    <Button Content="Reset zoom" Click="OnResetZoomClick" />
                </WrapPanel>
                <TextBlock x:Name="CursorInfoText"
                           Text="Cursor: - | A: - | B: - | dt: -"
                           Margin="0,4,0,0" />
                <TextBlock x:Name="CursorValueText"
                           Text="Signaalwaarde: -"
                           Margin="0,1,0,0" />
                <TextBlock Text="Tip: klik op legendanaam om lijn aan/uit te zetten. Ctrl+klik = Flag A, Shift+klik = Flag B, Ctrl+muiswiel = alleen actieve subplot Y-zoom, dubbelklik = reset, omgekeerde box-select = uitzoomen."
                           Foreground="#444444"
                           Margin="0,1,0,0" />
            </StackPanel>
        </Border>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Panels}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="#D8D8D8"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="6"
                                Margin="0,0,0,6">
                            <StackPanel>
                                <TextBlock Text="{Binding Title}"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,4" />
                                <oxy:PlotView Model="{Binding PlotModel}"
                                              Controller="{Binding PlotController}"
                                              PreviewMouseDown="OnPlotPreviewMouseDown"
                                              MouseMove="OnPlotMouseMove"
                                              Height="{Binding DataContext.SubplotHeight, RelativeSource={RelativeSource AncestorType=Window}}" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</Window>
